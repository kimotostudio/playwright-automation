{
    "mode":  "SEMI_AUTO",
    "stop":  false,
    "dry_run":  false,
    "wrap_message":  false,
    "wrap_width":  56,
    "daily_limit":  10,
    "aggressive_skip":  false,
    "skip_on_missing_demo_url":  false,
    "max_contact_page_seconds":  25,
    "max_form_detect_seconds":  20,
    "max_fill_seconds":  20,
    "skip_if_new_tabs_or_downloads":  true,
    "skip_if_requires_login":  true,
    "skip_if_iframe_only_form":  false,
    "skip_if_too_many_required_fields":  10,
    "skip_if_unfilled_required_fields":  true,
    "skip_if_submit_not_found":  true,
    "record_blocked_as_prepared":  false,
    "max_contact_candidate_links":  80,
    "max_contact_pages_to_try":  8,
    "allow_querystring_urls":  true,
    "contact_link_text_keywords":  [
                                       "お問い合わせ",
                                       "contact",
                                       "form",
                                       "予約",
                                       "reserve",
                                       "booking",
                                       "inquiry",
                                       "ご相談",
                                       "申し込み",
                                       "entry"
                                   ],
    "min_delay_sec":  5,
    "max_delay_sec":  5,
    "cooldown_on_error_min_sec":  30,
    "cooldown_on_error_max_sec":  90,
    "consecutive_failure_pause_threshold":  3,
    "consecutive_failure_pause_minutes":  10,
    "max_attempts_per_domain_per_day":  2,
    "headless":  true,
    "timeout_seconds":  30,
    "screenshot_enabled":  true,
    "timezone":  "Asia/Tokyo",
    "test_mode":  false,
    "test_limit":  2,
    "retry_max":  2,
    "allow_submit":  true,
    "respect_robots_and_terms":  true,
    "business_only_filter":  true,
    "quiet_hours_start":  22,
    "quiet_hours_end":  8,
    "domain_cooldown_days":  7,
    "log_format":  "text",
    "contact_page_patterns":  [
                                  "/contact",
                                  "/inquiry",
                                  "/お問い合わせ",
                                  "/お問合せ",
                                  "/otoiawase",
                                  "/mail",
                                  "/form",
                                  "/ask"
                              ],
    "browser":  {
                    "user_agent":  "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36",
                    "viewport_width":  1280,
                    "viewport_height":  720,
                    "locale":  "ja-JP"
                },
    "leads_csv_path":  "data/leads.csv",
    "aidnet_domain_list_path":  "data/エイドネット_ドメインリスト - リスト_日本語学校.csv",
    "debug":  false,
    "skip_domains":  [
                         "hotpepper.jp",
                         "beauty.hotpepper.jp",
                         "ekiten.jp",
                         "my-best.com"
                     ],
    "skip_url_keywords":  [
                              "hotpepper",
                              "ekiten",
                              "my-best"
                          ],
    "keep_browser_open":  true
}
